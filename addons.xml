<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
  <addon id="plugin.audio.m3sr2019" name="MP3 Streams Echoed" version="2026.1.0" provider-name="Echostorm / Claude">
    <requires>
      <import addon="xbmc.python" version="3.0.0"/>
      <import addon="script.module.beautifulsoup4"/>
      <import addon="script.module.requests"/>
      <import addon="script.module.routing"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>audio</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <reuselanguageinvoker>true</reuselanguageinvoker>
      <platform>all</platform>
      <license>GPL-3.0</license>
      <summary>MP3 Streams Echoed — music streaming for Kodi</summary>
      <description>Browse and stream songs and albums. Browse by genre, search artists, albums or songs, save favourites, play or shuffle full albums, and stream tracks directly in Kodi.</description>
      <assets>
        <icon>resources/media/icon.png</icon>
        <fanart>resources/media/fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
  <addon id="repository.echostorm" name="EchoRepo" version="1.0.1" provider-name="Echo-Storm">
    <extension point="xbmc.addon.repository" name="EchoRepo">
      <info compressed="false">https://raw.githubusercontent.com/Echo-Storm/EchoRepo/main/addons.xml</info>
      <checksum>https://raw.githubusercontent.com/Echo-Storm/EchoRepo/main/addons.xml.md5</checksum>
      <datadir zip="true">https://raw.githubusercontent.com/Echo-Storm/EchoRepo/main</datadir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary>Echo-Storm's Kodi Repository</summary>
      <description>Repository for Echo-Storm's custom Kodi addons, skins, and tools</description>
      <platform>all</platform>
      <assets>
        <icon>icon/icon.png</icon>
        <fanart>fanart/fanart.jpg</fanart>
      </assets>
    </extension>
  </addon>
</addons>