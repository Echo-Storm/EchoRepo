<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="weather.kodiweather" name="Kodi Weather" version="2.4.7" provider-name="Echo-Storm">
	<requires>
		<import addon="xbmc.python" version="3.0.0"/>
		<import addon="script.module.requests" version="2.27.1+matrix.1"/>
		<import addon="script.module.dateutil" version="2.8.1+matrix.1"/>
		<import addon="script.module.pytz" version="2023.3.0+matrix.1"/>
		<import addon="script.module.pil" version="1.1.7"/>
	</requires>
	<extension point="xbmc.python.weather" library="default.py"/>
	<extension point="xbmc.service" library="service.py" />
	<extension point="xbmc.addon.metadata">
		<summary lang="en_GB">Kodi Weather</summary>
		<description lang="en_GB">Aeon Echostorm Edition Weather, maps, and alerts for US locations.</description>
		<platform>all</platform>
		<license>MIT</license>
		<source>https://github.com/Echo-Storm</source>
        <assets>
            <icon>icon.png</icon>
            <fanart>fanart.jpg</fanart>
        </assets>
	</extension>
</addon>
